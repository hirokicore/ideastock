{
  "name": "ideastock-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:ideastock": "npm run dev --workspace=apps/ideastock",
    "dev:business-plan": "npm run dev --workspace=apps/business-plan",
    "build:ideastock": "npm run build --workspace=apps/ideastock",
    "build:business-plan": "npm run build --workspace=apps/business-plan",
    "lint:ideastock": "npm run lint --workspace=apps/ideastock",
    "lint:business-plan": "npm run lint --workspace=apps/business-plan"
  }
}
